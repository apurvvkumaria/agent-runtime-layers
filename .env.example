# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored; this template is safe to commit (no real secrets).

# Claude API key — required for the LLM commands (chat, ask, research) and the
# /ask and /chat API endpoints. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LangFuse tracing — optional. Leave these as-is (or unset) to run with the
# built-in print hooks only; fill in real keys to send traces to LangFuse.
# Keys: LangFuse UI -> Settings -> API Keys.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
